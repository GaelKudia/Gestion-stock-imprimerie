<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Panneau de Contrôle Général - Administration</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    
    <style>
        .card-counter { shadow: 0 4px 10px rgba(0,0,0,0.05); border: none; border-radius: 10px; transition: transform 0.2s; }
        .card-counter:hover { transform: translateY(-3px); }
        .nav-tabs .nav-link.active { border-bottom: 3px solid #0d6efd !important; font-weight: bold; }
        .sticky-form { position: sticky; top: 20px; }
    </style>
</head>
<body class="bg-light text-dark">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold fs-4" href="#">
                <i class="fas fa-print text-danger me-2"></i>Dispro<span class="text-primary">malt</span> <span class="fw-light fs-5 text-muted">| Gérant Imprimerie</span>
            </a>
            <div class="d-flex align-items-center">
                <div class="bg-secondary bg-opacity-20 text-white px-3 py-1.5 rounded-pill me-3 small border border-secondary">
                    <i class="fas fa-user-shield text-warning me-2"></i><strong>Super-Administrateur</strong>
                </div>
                <a href="/logout" class="btn btn-primary btn-sm fw-bold px-3">
                    <i class="fas fa-sign-out-alt me-1"></i> Déconnexion
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid py-4 px-4">
        
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
            <div>
                <h1 class="fw-bold text-dark m-0">Tableau de Bord Général</h1>
                <p class="text-muted m-0">Supervision des flux de l'imprimerie et gestion globale des identifiants des agents.</p>
            </div>
            <div class="text-end text-muted small font-monospace">
                <i class="fas fa-calendar-alt me-1"></i> Système Actif & Sécurisé
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4 border-start border-success border-4" role="alert">
                    <i class="fas fa-check-circle text-success me-2 fs-5"></i> <strong>Succès :</strong> {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="row g-3 mb-4">
            <div class="col-md-4 col-xl-3">
                <div class="card card-counter bg-white p-4 shadow-sm border-start border-primary border-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase small fw-bold">Demandes Totales</h6>
                            <h3 class="fw-bold m-0 text-primary">{{ demandes|length }}</h3>
                        </div>
                        <i class="fas fa-box fa-2x text-primary bg-primary bg-opacity-10 p-3 rounded-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-xl-3">
                <div class="card card-counter bg-white p-4 shadow-sm border-start border-success border-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase small fw-bold">Bons de Sortie</h6>
                            <h3 class="fw-bold m-0 text-success">{{ bons|length }}</h3>
                        </div>
                        <i class="fas fa-file-signature fa-2x text-success bg-success bg-opacity-10 p-3 rounded-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-xl-3">
                <div class="card card-counter bg-white p-4 shadow-sm border-start border-purple border-4" style="border-left-color: #6f42c1 !important;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase small fw-bold">Agents Enregistrés</h6>
                            <h3 class="fw-bold m-0" style="color: #6f42c1;">{{ users|length }}</h3>
                        </div>
                        <i class="fas fa-users fa-2x text-purple bg-purple bg-opacity-10 p-3 rounded-circle" style="color: #6f42c1;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            
            <div class="col-xl-4 col-lg-5">
                <div class="sticky-form">
                    <div class="card border-0 shadow-sm mb-4" style="border-top: 4px solid #6f42c1 !important;">
                        <div class="card-header bg-white py-3">
                            <h5 class="card-title m-0 fw-bold text-dark">
                                <i class="fas fa-user-plus me-2" style="color: #6f42c1;"></i>Créer un Compte Agent
                            </h5>
                        </div>
                        <div class="card-body">
                            {{ form_start(form) }}
                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-secondary">Adresse Email de connexion</label>
                                    {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'agent.nom@imprimerie.com'}}) }}
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-secondary">Département d'affectation</label>
                                    {{ form_widget(form.roles, {'attr': {'class': 'form-select'}}) }}
                                </div>
                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-secondary">Mot de passe provisoire</label>
                                    {{ form_widget(form.password, {'attr': {'class': 'form-control', 'placeholder': 'Mot de passe'}}) }}
                                </div>
                                <button type="submit" class="btn w-100 fw-bold text-white shadow-sm" style="background-color: #6f42c1;">
                                    <i class="fas fa-check-shield me-2"></i>Générer et Activer l'Accès
                                </button>
                            {{ form_end(form) }}
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white py-3">
                            <h6 class="m-0 fw-bold text-dark"><i class="fas fa-users-cog me-2 text-muted"></i>Statut des Comptes ({{ users|length }})</h6>
                        </div>
                        <div class="card-body p-0" style="max-height: 220px; overflow-y: auto;">
                            <div class="list-group list-group-flush">
                                {% for u in users %}
                                    <div class="list-group-item p-3 d-flex justify-content-between align-items-center small">
                                        <div>
                                            <span class="d-block fw-bold text-dark">{{ u.email }}</span>
                                            <span class="badge bg-light text-secondary border font-monospace mt-1" style="font-size: 10px;">{{ u.roles[0] }}</span>
                                        </div>
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle rounded-pill px-2">Actif</span>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-8 col-lg-7">
                <div class="card border-0 shadow-sm h-100">
                    
                    <div class="card-header bg-white p-0 border-bottom">
                        <ul class="nav nav-tabs card-header-tabs m-0 border-bottom-0" id="panelTab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active py-3 px-4 fw-bold border-0 text-primary" id="demandes-tab" data-bs-toggle="tab" data-bs-target="#demandes-pane" type="button" role="tab">
                                    <i class="fas fa-boxes me-2"></i>Suivi des Demandes de Matériel
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link py-3 px-4 fw-bold border-0 text-success" id="bons-tab" data-bs-toggle="tab" data-bs-target="#bons-pane" type="button" role="tab">
                                    <i class="fas fa-id-badge me-2"></i>Registre des Bons de Sortie
                                </button>
                            </li>
                        </ul>
                    </div>

                    <div class="card-body p-3">
                        <div class="tab-content" id="panelTabContent">
                            
                            <div class="tab-pane fade show active" id="demandes-pane" role="tabpanel" aria-labelledby="demandes-tab">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle m-0">
                                        <thead class="table-light small text-uppercase fw-bold text-secondary">
                                            <tr>
                                                <th>Code</th>
                                                <th>Département</th>
                                                <th>Matériel Demandé</th>
                                                <th>Quantité</th>
                                                <th>État</th>
                                                <th class="text-center">Actions / Contrôle</th>
                                            </tr>
                                        </thead>
                                        <tbody class="small">
                                            {% for d in demandes %}
                                                <tr>
                                                    <td class="fw-bold text-secondary">#{{ d.id }}</td>
                                                    <td><span class="badge bg-secondary bg-opacity-10 text-secondary border px-2 py-1">{{ d.departement }}</span></td>
                                                    <td class="fw-semibold text-dark">{{ d.materiel }}</td>
                                                    <td><span class="badge bg-light text-dark border px-2 py-1">{{ d.quantite }}</span></td>
                                                    <td>
                                                        <span class="badge rounded-pill px-2.5 py-1 {% if d.statut == 'En attente' %}bg-warning text-dark{% elseif 'Livré' in d.statut %}bg-info text-white{% else %}bg-success{% endif %}">
                                                            {{ d.statut }}
                                                        </span>
                                                    </td>
                                                    <td class="text-center">
                                                        <div class="btn-group btn-group-sm shadow-sm" role="group">
                                                            <button class="btn btn-light border text-primary" title="Voir les détails"><i class="fas fa-eye"></i></button>
                                                            <button class="btn btn-light border text-success" title="Valider la demande"><i class="fas fa-check"></i></button>
                                                            <button class="btn btn-light border text-danger" title="Refuser la demande"><i class="fas fa-times"></i></button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            {% else %}
                                                <tr>
                                                    <td colspan="6" class="text-center py-5 text-muted">
                                                        <i class="fas fa-folder-open d-block fs-3 mb-2"></i> Aucune demande de matériel enregistrée.
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="bons-pane" role="tabpanel" aria-labelledby="bons-tab">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle m-0">
                                        <thead class="table-light small text-uppercase fw-bold text-secondary">
                                            <tr>
                                                <th>Code</th>
                                                <th>Nom de l'Agent</th>
                                                <th>Département</th>
                                                <th>Référence du Bon</th>
                                                <th>État Sécurité</th>
                                                <th class="text-center">Actions / Contrôle</th>
                                            </tr>
                                        </thead>
                                        <tbody class="small">
                                            {% for b in bons %}
                                                <tr>
                                                    <td class="fw-bold text-secondary">#{{ b.id }}</td>
                                                    <td class="fw-semibold text-dark">{{ b.nomEmploye }}</td>
                                                    <td><span class="badge bg-secondary bg-opacity-10 text-secondary border px-2 py-1">{{ b.departement }}</span></td>
                                                    <td><span class="text-muted">Bon d'autorisation n°{{ b.id }}</span></td>
                                                    <td>
                                                        <span class="badge rounded-pill px-2.5 py-1 {% if b.statut == 'Créé' %}bg-warning text-dark{% elseif b.statut == 'Validé Coordon' %}bg-primary{% else %}bg-success{% endif %}">
                                                            {{ b.statut }}
                                                        </span>
                                                    </td>
                                                    <td class="text-center">
                                                        <div class="btn-group btn-group-sm shadow-sm" role="group">
                                                            <button class="btn btn-light border text-primary" title="Imprimer le bon"><i class="fas fa-print"></i></button>
                                                            <button class="btn btn-light border text-success" title="Autoriser le passage"><i class="fas fa-shield-check"></i></button>
                                                            <button class="btn btn-light border text-danger" title="Bloquer le passage"><i class="fas fa-ban"></i></button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            {% else %}
                                                <tr>
                                                    <td colspan="6" class="text-center py-5 text-muted">
                                                        <i class="fas fa-users-slash d-block fs-3 mb-2"></i> Aucun bon de sortie en circulation.
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>