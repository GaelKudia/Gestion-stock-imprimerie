<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Connexion - Imprimerie Gérant</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>
<body class="bg-secondary bg-opacity-10">

    {# Écran de connexion totalement isolé, aucun menu ne peut s'infiltrer ici #}
    <div class="d-flex align-items-center justify-content-center" style="min-height: 100vh; width: 100vw;">
        
        <div class="login-box shadow-lg rounded p-4 bg-white" style="width: 100%; max-width: 400px; border-top: 4px solid #dc3545;">
            
            <div class="login-logo text-center mb-4">
                <h2 class="fw-bold m-0 text-dark">
                    <i class="fas fa-print text-danger me-2"></i><b>Admin</b>LTE
                </h2>
                <small class="text-muted text-uppercase tracking-wider font-monospace" style="font-size: 11px;">
                    Gestion des Flux & Sécurité
                </small>
            </div>

            <div class="card-body login-card-body p-0">
                <p class="login-box-msg text-center text-muted small mb-4">
                    Identifiez-vous pour démarrer votre session de travail
                </p>

                <form method="post">
                    {% if error %}
                        <div class="alert alert-danger shadow-sm border-0 mb-3 small d-flex align-items-center">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                        </div>
                    {% endif %}

                    <div class="input-group mb-3 shadow-sm">
                        <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" placeholder="Adresse Email" autocomplete="email" required autofocus>
                        <div class="input-group-text bg-light text-muted border-start-0">
                            <span class="fas fa-envelope"></span>
                        </div>
                    </div>

                    <div class="input-group mb-4 shadow-sm">
                        <input type="password" name="password" id="inputPassword" class="form-control" placeholder="Mot de passe" autocomplete="current-password" required>
                        <div class="input-group-text bg-light text-muted border-start-0">
                            <span class="fas fa-lock"></span>
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div class="row align-items-center">
                        <div class="col-7">
                            <div class="form-check m-0">
                                <input class="form-check-input" type="checkbox" name="_remember_me" id="remember_me">
                                <label class="form-check-label small text-muted fw-semibold" for="remember_me">
                                    Se souvenir de moi
                                </label>
                            </div>
                        </div>
                        <div class="col-5">
                            <button class="btn btn-danger btn-block w-100 fw-bold shadow-sm" type="submit">
                                <i class="fas fa-sign-in-alt me-1"></i> Connexion
                            </button>
                        </div>
                    </div>
                </form>
                
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>