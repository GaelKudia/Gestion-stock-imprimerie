{% extends 'base.html.twig' %}

{% block title %}Connexion - Gestion Digitale de Stock{% endblock %}

{% block body %}
<div class="login-container">
    
    <div style="font-size: 45px; margin-bottom: 5px;">🖨️</div>

    <div class="login-title">Connexion</div>
    <div class="login-subtitle">
        Gestion Digitale de Stock v1.0<br>
        <span style="font-size: 12px; color: #a0aec0;">v1.0.229 (2026051701)</span>
    </div>

    <form method="post">
        {% if error %}
            <div style="color: #e53e3e; background: #fff5f5; padding: 10px; border-radius: 6px; margin-bottom: 15px; font-size: 14px; border: 1px solid #fed7d7;">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <div class="form-group-custom">
            <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" class="form-control-custom input-email" placeholder="Email*" autocomplete="email" required autofocus>
        </div>

        <div class="form-group-custom">
            <input type="password" name="_password" id="inputPassword" class="form-control-custom input-password" placeholder="Mot de passe*" autocomplete="current-password" required>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button class="btn-custom" type="submit">
            Connexion
        </button>
    </form>
</div>
{% endblock %}