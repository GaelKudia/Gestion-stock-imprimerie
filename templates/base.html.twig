<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Gestion Digitale de Stock{% endblock %}</title>
        <link rel="stylesheet" href="{{ asset('css/style.css') }}">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        
        {# 1. La barre de navigation (s'affiche uniquement si connecté) #}
        {% if app.user %}
            <nav class="navbar-custom">
                <a class="navbar-brand-custom" href="{{ path('app_produit_index') }}">🖨️ Gestion Digitale de Stock</a>
                <div style="display: flex; align-items: center; gap: 20px;">
                    <span style="color: #64748b; font-size: 14px;">👤 {{ app.user.userIdentifier }}</span>
                    <a href="{{ path('app_logout') }}" style="color: #ef4444; text-decoration: none; font-size: 14px; font-weight: 600;">Déconnexion</a>
                </div>
            </nav>
        {% endif %}

        {# 2. LE SEUL ET UNIQUE BLOC BODY DU FICHIER #}
        {# On applique la classe CSS de mise en page uniquement si l'utilisateur est connecté #}
        <div class="{% if app.user %}dashboard-container{% endif %}">
            {% block body %}{% endblock %}
        </div>

        {% block javascripts %}{% endblock %}
    </body>
</html>