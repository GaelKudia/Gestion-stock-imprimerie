<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}STOCK IMPRIMERIE | AdminLTE 4{% endblock %}</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    
    <style>
        body { overflow-x: hidden; background-color: #f4f6f9; font-family: 'Source Sans Pro', sans-serif; }
        
        /* Sidebar latérale gauche (Style AdminLTE 4) */
        .sidebar { width: 250px; height: 100vh; position: fixed; top: 0; left: 0; background-color: #343a40; color: #c2c7d0; z-index: 1000; }
        .sidebar .brand-link { padding: 15px; font-size: 1.25rem; background-color: #22252a; color: #fff; text-decoration: none; display: block; border-bottom: 1px solid #4b545c; }
        .sidebar .nav-link { color: #c2c7d0; padding: 10px 15px; display: block; text-decoration: none; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background-color: rgba(255,255,255,0.1); color: #fff; border-left: 3px solid #0d6efd; }
        
        /* Contenu principal à droite */
        .main-wrapper { margin-left: 250px; min-height: 100vh; }
        
        /* Navbar supérieure (Style AdminLTE 4) */
        .top-navbar { background-color: #fff; border-bottom: 1px solid #dee2e6; padding: 10px 20px; }
        .content-header { padding: 15px 20px; }
        .content-body { padding: 0 20px 20px 20px; }
        
        /* Styles AdminLTE pour les 4 cartes du matin */
        .small-box { position: relative; display: block; border-radius: 0.25rem; box-shadow: 0 1px 3px rgba(0,0,0,.15); margin-bottom: 20px; padding: 20px; color: #fff; text-decoration: none; }
        .small-box h3 { font-size: 2.2rem; font-weight: 700; margin: 0 0 10px 0; }
        .small-box .icon { position: absolute; top: 15px; right: 15px; font-size: 60px; color: rgba(0,0,0,0.15); }
        .small-box .small-box-footer { text-align: center; padding: 3px 0; color: rgba(255,255,255,0.8); display: block; background-color: rgba(0,0,0,0.1); text-decoration: none; margin: 20px -20px -20px -20px; border-bottom-left-radius: 0.25rem; border-bottom-right-radius: 0.25rem; }
        .small-box .small-box-footer:hover { color: #fff; background-color: rgba(0,0,0,0.15); }

        /* Utilitaires pour forcer le centrage parfait du tableau */
        .table-centered-container { display: flex; justify-content: center; width: 100%; }
        .table-centered-content { width: 100%; max-width: 1100px; }
        
        /* Animation de transition pour le menu et le contenu */
        .sidebar, .main-wrapper {
            transition: all 0.3s ease-in-out;
        }

        /* Classe magique qui va masquer le menu latéral */
        .sidebar.collapsed {
            left: -250px;
        }

        /* Classe magique qui va élargir le contenu principal quand le menu disparaît */
        .main-wrapper.expanded {
            margin-left: 0;
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

    <div class="sidebar">
        <a href="{{ path('app_dashboard') }}" class="brand-link text-center fw-bold">
            <span class="border rounded-circle px-2 py-1 me-2">I</span>Imprimerie Stock
        </a>
        <div class="p-3">
        {# 🚪 SI LA ROUTE N'EST PAS LE LOGIN, ON AFFICHE LE MENU #}
        {% if app.request.attributes.get('_route') != 'app_login' %}
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
                <div class="container-fluid">
                    <a class="navbar-brand" href="#">Imprimerie Admin</a>
                    </div>
            </nav>
        {% endif %}

        {# Contenu principal de tes pages #}
        <div class="content-wrapper">
            {% block body %}{% endblock %}
        </div>
            <small class="text-uppercase text-muted fw-bold d-block mb-2" style="font-size: 0.75rem;">Menu Principal</small>
            <nav class="nav flex-column">
                <a class="nav-link active mb-1 rounded" href="{{ path('app_dashboard') }}">
                    <i class="fa-solid fa-gauge-high me-2"></i> Dashboard
                </a>

                {# 📅 ACCESSIBLE PAR TOUT LE MONDE SANS EXCEPTION #}
                <a class="nav-link mb-1 rounded" href="#">
                    <i class="fa-solid fa-calendar-days me-2"></i> Prévenir un RDV / Visite
                </a>

                {# 📦 UNIQUEMENT LES SERVICES AUTORISÉS À DEMANDER (ROLE_USER) #}
                {% if is_granted('ROLE_USER') %}
                    <a class="nav-link mb-1 rounded" href="#">
                        <i class="fa-solid fa-box-open me-2"></i> Demander du Matériel
                    </a>
                {% endif %}

                {# 🔑 LOGISTIQUE & FLUX : ACCÈS DU GÉRANT DE STOCK ET COMPTA #}
                {% if is_granted('ROLE_STOCK') or is_granted('ROLE_COMPTA') %}
                    <a class="nav-link mb-1 rounded" href="#">
                        <i class="fa-solid fa-boxes-stacked me-2"></i> Gestion des Stocks
                    </a>
                {% endif %}

                {# 📄 EXCLUSIF RÉCEPTION ET COORDONNATEUR #}
                {% if is_granted('ROLE_RECEPTION') or is_granted('ROLE_COORDON') %}
                    <a class="nav-link mb-1 rounded" href="#">
                        <i class="fa-solid fa-file-signature me-2"></i> Bons de Sortie
                    </a>
                {% endif %}

                {# 🛡️ EXCLUSIF SÉCURITÉ GUÉRITE #}
                {% if is_granted('ROLE_GUERITE') %}
                    <a class="nav-link mb-1 rounded" href="#">
                        <i class="fa-solid fa-shield-halved me-2"></i> Contrôle Guérite
                    </a>
                {% endif %}
            </nav>
        </div>
    </div>

    <div class="main-wrapper">
        
        <div class="top-navbar d-flex justify-content-between align-items-center shadow-sm">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-link text-dark p-0" id="toggleSidebar">
                    <i class="fa-solid fa-bars fs-5"></i>
                </button>
                <span class="text-muted fw-medium">Espace Gestion de Flux</span>
            </div>
            
            <div class="d-flex align-items-center gap-3">
                {% if app.user %}
                    <span class="fw-semibold text-dark"><i class="fa-solid fa-user me-1 text-secondary"></i> {{ app.user.userIdentifier }}</span>
                    <a href="{{ path('app_logout') }}" class="btn btn-danger btn-sm rounded-pill px-3">Sign out</a>
                {% else %}
                    <span class="fw-semibold text-dark"><i class="fa-solid fa-user me-1 text-secondary"></i> Gael (Mode Dev)</span>
                {% endif %}
            </div>
        </div>

        <div class="content-header d-flex justify-content-between align-items-center">
            <h1 class="h3 m-0 fw-bold text-dark">Dashboard</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb m-0 fs-7">
                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Home</a></li>
                    <li class="breadcrumb-item active text-dark" aria-current="page">Dashboard</li>
                </ol>
            </nav>
        </div>

        <div class="content-body">
            
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.getElementById('toggleSidebar').addEventListener('click', function(e) {
            e.preventDefault();
            document.querySelector('.sidebar').classList.toggle('collapsed');
            document.querySelector('.main-wrapper').classList.toggle('expanded');
        });
    </script>
    
    {% block javascripts %}{% endblock %}
</body>
</html>