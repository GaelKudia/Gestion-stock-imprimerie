<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Espace Accueil - Imprimerie</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>
<body class="bg-light text-dark">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold fs-4" href="#">
                <i class="fas fa-print text-danger me-2"></i>Admin<span class="text-danger">LTE</span> <span class="fw-light fs-5 text-muted">| Accueil</span>
            </a>
            <div class="d-flex align-items-center">
                <div class="bg-secondary bg-opacity-20 text-white px-3 py-1.5 rounded-pill me-3 small border border-secondary">
                    <i class="fas fa-bell text-warning me-2"></i>Rôle actif : <strong>{{ userRole }}</strong>
                </div>
                <a href="/logout" class="btn btn-danger btn-sm fw-bold px-3">
                    <i class="fas fa-sign-out-alt me-1"></i> Déconnexion
                </a>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="mb-4 pb-3 border-bottom">
            <h1 class="fw-bold"><i class="fas fa-concierge-bell text-info me-2"></i>Registre de l'Accueil</h1>
            <p class="text-muted">Gérez les visiteurs actuellement présents dans les locaux de l'imprimerie.</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-info alert-dismissible fade show shadow-sm mb-4" role="alert">
                    <i class="fas fa-info-circle me-2"></i> {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="card-title m-0 fw-bold text-secondary"><i class="fas fa-users me-2"></i>Visiteurs en attente ou présents</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle m-0">
                        <thead class="table-light small text-uppercase fw-bold text-secondary">
                            <tr>
                                <th>Nom du Visiteur</th>
                                <th>Département Visité</th>
                                <th>Motif</th>
                                <th>Statut</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody class="small">
                            {% for v in visites %}
                                <tr>
                                    <td class="fw-bold text-dark">{{ v.nomVisiteur }}</td>
                                    <td><span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-2 py-1">{{ v.departement }}</span></td>
                                    <td class="text-muted">{{ v.motif }}</td>
                                    <td><span class="badge bg-success px-2.5 py-1">À l'Accueil / Présent</span></td>
                                    <td class="text-center">
                                        <form action="{{ path('app_visite_cloturer', {'id': v.id}) }}" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-dark fw-bold px-3">
                                                <i class="fas fa-door-closed me-1"></i> Signaler le Départ
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i class="fas fa-user-clock fa-2x mb-3 text-muted opacity-50 d-block"></i>
                                        Aucun visiteur signalé à l'accueil pour le moment.
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>