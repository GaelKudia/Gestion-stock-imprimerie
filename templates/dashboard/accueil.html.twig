<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Espace Accueil - Dispromalt</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        /* 🔵 Personnalisation de la couleur active de l'onglet en bleu Dispromalt */
        .nav-tabs .nav-link.active { border-bottom: 3px solid #0d6efd !important; font-weight: bold; color: #0d6efd !important; }
        .nav-tabs .nav-link { color: #6c757d; }
    </style>
</head>
<body class="bg-light text-dark">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3">
        <div class="container-fluid px-4">
            {# 🔵 Remplacement par DisproMalt en BLEU #}
            <a class="navbar-brand fw-bold fs-4" href="#">
                <i class="fas fa-print text-primary me-2"></i>Dispro<span class="text-primary">malt</span> <span class="fw-light fs-5 text-muted">| Accueil</span>
            </a>
            <div class="d-flex align-items-center">
                <div class="bg-secondary bg-opacity-20 text-white px-3 py-1.5 rounded-pill me-3 small border border-secondary">
                    <i class="fas fa-concierge-bell text-warning me-2"></i>Rôle actif : <strong>{{ userRole }}</strong>
                </div>
                {# 🔵 Bouton déconnexion en bleu #}
                <a href="/logout" class="btn btn-primary btn-sm fw-bold px-3">
                    <i class="fas fa-sign-out-alt me-1"></i> Déconnexion
                </a>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="mb-4 pb-3 border-bottom">
            <h1 class="fw-bold"><i class="fas fa-desktop text-info me-2"></i>Espace Opérationnel - Accueil</h1>
            <p class="text-muted m-0">Gérez le registre des présences, planifiez des visites et créez des bons de sortie de matériel.</p>
        </div>

        {# Messages Flash #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{% if label == 'danger' %}danger{% else %}info{% endif %} alert-dismissible fade show shadow-sm mb-4" role="alert">
                    <i class="fas fa-info-circle me-2"></i> {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}
        {% endfor %}

        {# Système d'onglets #}
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white p-0 border-bottom">
                <ul class="nav nav-tabs card-header-tabs m-0 border-bottom-0" id="accueilTab" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active py-3 px-4 fw-bold border-0" id="registre-tab" data-bs-toggle="tab" data-bs-target="#registre-pane" type="button" role="tab">
                            <i class="fas fa-users text-info me-2"></i>Visiteurs Présents
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link py-3 px-4 fw-bold border-0" id="visite-tab" data-bs-toggle="tab" data-bs-target="#visite-pane" type="button" role="tab">
                            <i class="fas fa-calendar-plus text-success me-2"></i>Enregistrer une Visite
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link py-3 px-4 fw-bold border-0" id="bon-tab" data-bs-toggle="tab" data-bs-target="#bon-pane" type="button" role="tab">
                            <i class="fas fa-ticket-alt text-primary me-2"></i>Créer un Bon de Sortie
                        </button>
                    </li>
                </ul>
            </div>
            
            <div class="card-body p-4">
                <div class="tab-content">
                    
                    {# ONGLET 1 : REGISTRE DES VISITEURS #}
                    <div class="tab-pane fade show active" id="registre-pane" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle m-0">
                                <thead class="table-light small text-uppercase fw-bold text-secondary">
                                    <tr>
                                        <th>Nom du Visiteur</th>
                                        <th>Département Visité</th>
                                        <th>Motif</th>
                                        <th>Statut</th>
                                        <th class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <tbody class="small">
                                    {% for v in visites %}
                                        <tr>
                                            <td class="fw-bold text-dark">{{ v.nomVisiteur }}</td>
                                            <td><span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-2 py-1">{{ v.departement }}</span></td>
                                            <td class="text-muted">{{ v.motif }}</td>
                                            <td><span class="badge bg-success px-2.5 py-1">À l'Accueil / Présent</span></td>
                                            <td class="text-center">
                                                <form action="{{ path('app_visite_cloturer', {'id': v.id}) }}" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-dark fw-bold px-3">
                                                        <i class="fas fa-door-closed me-1"></i> Signaler le Départ
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="5" class="text-center py-5 text-muted">
                                                <i class="fas fa-user-clock fa-2x mb-3 text-muted opacity-50 d-block"></i>
                                                Aucun visiteur signalé à l'accueil pour le moment.
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    {# ONGLET 2 : FORMULAIRE DE RÉSERVATION DE VISITE #}
                    <div class="tab-pane fade" id="visite-pane" role="tabpanel">
                        <div class="d-flex justify-content-center py-2">
                            <div class="card border p-4 shadow-sm bg-white" style="width: 100%; max-width: 550px; border-radius: 12px;">
                                <div class="text-center mb-4">
                                    <i class="fas fa-id-card text-success fa-2x mb-2"></i>
                                    <h5 class="fw-bold text-dark m-0">Nouvelle Fiche Visiteur</h5>
                                    <small class="text-muted">Planifier l'accès d'un tiers dans l'imprimerie</small>
                                </div>
                                
                                {% if formVisite is defined and formVisite is not null %}
                                    {{ form_start(formVisite) }}
                                        <div class="mb-3">
                                            <label class="form-label small fw-bold text-secondary">Nom & Prénom du Visiteur</label>
                                            {{ form_widget(formVisite.nomVisiteur, {'attr': {'class': 'form-control py-2', 'placeholder': 'Ex: Jean Dupont'}}) }}
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label small fw-bold text-secondary">Département Visité</label>
                                            {{ form_widget(formVisite.departement, {'attr': {'class': 'form-control py-2'}}) }}
                                        </div>
                                        <div class="mb-4">
                                            <label class="form-label small fw-bold text-secondary">Motif de la visite</label>
                                            {{ form_widget(formVisite.motif, {'attr': {'class': 'form-control py-2', 'rows': '2'}}) }}
                                        </div>
                                        <button type="submit" class="btn btn-success w-100 fw-bold py-2">
                                            <i class="fas fa-save me-2"></i>Enregistrer et Réserver
                                        </button>
                                    {{ form_end(formVisite) }}
                                {% else %}
                                    <p class="text-danger text-center">Le formulaire de visite (VisiteType) n'est pas lié ou disponible pour ce rôle.</p>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {# ONGLET 3 : FORMULAIRE DE BON DE SORTIE #}
                    <div class="tab-pane fade" id="bon-pane" role="tabpanel">
                        <div class="d-flex justify-content-center py-2">
                            <div class="card border p-4 shadow-sm bg-white" style="width: 100%; max-width: 550px; border-radius: 12px;">
                                <div class="text-center mb-4">
                                    {# 🔵 Icone et couleur changées en bleu principal #}
                                    <i class="fas fa-exchange-alt text-primary fa-2x mb-2"></i>
                                    <h5 class="fw-bold text-dark m-0">Créer un Bon de Sortie</h5>
                                    <small class="text-muted">Déclarer la sortie physique d'un matériel ou équipement</small>
                                </div>
                                
                                {% if formBon is defined and formBon is not null %}
                                    {{ form_start(formBon) }}
                                        <div class="mb-3">
                                            <label class="form-label small fw-bold text-secondary">Description / Renseignements du Bon</label>
                                            {{ form_widget(formBon) }}
                                        </div>
                                        {# 🔵 Bouton passé en bleu Bootstrap (btn-primary) #}
                                        <button type="submit" class="btn btn-primary w-100 fw-bold py-2 mt-2">
                                            <i class="fas fa-paper-plane me-2"></i>Transmettre pour Signature
                                        </button>
                                    {{ form_end(formBon) }}
                                {% else %}
                                    <p class="text-danger text-center">Le formulaire de Bon de Sortie (BonSortieType) n'est pas envoyé à la vue.</p>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>