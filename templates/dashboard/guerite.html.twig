<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Poste de Contrôle - Guérite Sécurité</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    
    <style>
        .card-counter { shadow: 0 4px 10px rgba(0,0,0,0.05); border: none; border-radius: 10px; transition: transform 0.2s; }
        .card-counter:hover { transform: translateY(-3px); }
    </style>
</head>
<body class="bg-light text-dark">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold fs-4" href="#">
                <i class="fas fa-shield-alt text-warning me-2"></i>Admin<span class="text-danger">LTE</span> <span class="fw-light fs-5 text-muted">| Sécurité Guérite</span>
            </a>
            <div class="d-flex align-items-center">
                <div class="bg-secondary bg-opacity-20 text-white px-3 py-1.5 rounded-pill me-3 small border border-secondary">
                    <i class="fas fa-user-shield text-warning me-2"></i><strong>Agent de Sécurité</strong>
                </div>
                <a href="/logout" class="btn btn-danger btn-sm fw-bold px-3">
                    <i class="fas fa-sign-out-alt me-1"></i> Déconnexion
                </a>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
            <div>
                <h1 class="fw-bold text-dark m-0">Contrôle des Sorties Physiques</h1>
                <p class="text-muted m-0">Vérification et validation en temps réel des bons de sortie de l'imprimerie.</p>
            </div>
            <div class="text-end text-muted small font-monospace">
                <i class="fas fa-clock me-1"></i> Poste de Contrôle Actif
            </div>
        </div>

        <div class="row g-3 mb-4 justify-content-center justify-content-md-start">
            <div class="col-md-6 col-xl-4">
                <div class="card card-counter bg-white p-4 shadow-sm border-start border-warning border-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase small fw-bold">Bons en Circulation</h6>
                            <h3 class="fw-bold m-0 text-warning">
                                {# Sécurité : évite le plantage si la variable n'existe pas #}
                                {% if bons is defined %}{{ bons|length }}{% else %}0{% endif %}
                            </h3>
                        </div>
                        <i class="fas fa-file-invoice fa-2x text-warning bg-warning bg-opacity-10 p-3 rounded-circle"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white py-3 border-0">
                        <h4 class="card-title m-0 fw-bold text-dark">
                            <i class="fas fa-list-check me-2 text-muted"></i>Registre des autorisations de sortie
                        </h4>
                        <small class="text-muted">Interceptez le matériel et validez le passage des agents de la société.</small>
                    </div>
                    
                    <div class="card-body p-3">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle m-0">
                                <thead class="table-light small text-uppercase fw-bold text-secondary">
                                    <tr>
                                        <th>Code</th>
                                        <th>Nom de l'Agent</th>
                                        <th>Département</th>
                                        <th>Référence / Motif</th>
                                        <th>Statut Actuel</th>
                                        <th class="text-center">Action Sécurité</th>
                                    </tr>
                                </thead>
                                <tbody class="small">
                                    {# Sécurité sur la boucle #}
                                    {% if bons is defined and bons|length > 0 %}
                                        {% for b in bons %}
                                            <tr>
                                                <td class="fw-bold text-secondary">#{{ b.id }}</td>
                                                <td class="fw-semibold text-dark">{{ b.nomEmploye }}</td>
                                                <td><span class="badge bg-secondary bg-opacity-10 text-secondary border px-2 py-1">{{ b.departement }}</span></td>
                                                <td><span class="text-muted">Bon de sortie sécurisé n°{{ b.id }}</span></td>
                                                <td>
                                                    <span class="badge rounded-pill px-2.5 py-1 {% if b.statut == 'Créé' %}bg-warning text-dark{% elseif b.statut == 'Validé Coordon' %}bg-primary{% else %}bg-success{% endif %}">
                                                        {{ b.statut }}
                                                    </span>
                                                </td>
                                                <td class="text-center">
                                                    <div class="btn-group btn-group-sm shadow-sm" role="group">
                                                        <button class="btn btn-success fw-bold px-3">
                                                            <i class="fas fa-shield-check me-1"></i> Autoriser la sortie
                                                        </button>
                                                        <button class="btn btn-danger">
                                                            <i class="fas fa-ban"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    {% else %}
                                        <tr>
                                            <td colspan="6" class="text-center py-5 text-muted">
                                                <i class="fas fa-lock fs-2 d-block mb-2 text-muted"></i> Aucun bon de sortie n'est actif ou transmis à la guérite pour le moment.
                                            </td>
                                        </tr>
                                    {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>