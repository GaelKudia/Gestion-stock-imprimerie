<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Espace Membre & Validation - Imprimerie</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        .card-counter { border: none; border-radius: 10px; transition: transform 0.2s; }
        .card-counter:hover { transform: translateY(-3px); }
        .nav-tabs .nav-link.active { border-bottom: 3px solid #0d6efd !important; font-weight: bold; }
    </style>
</head>
<body class="bg-light text-dark">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold fs-4" href="#">
                <i class="fas fa-print text-danger me-2"></i>Admin<span class="text-danger">LTE</span> <span class="fw-light fs-5 text-muted">| Espace Opérationnel</span>
            </a>
            <div class="d-flex align-items-center">
                <div class="bg-secondary bg-opacity-20 text-white px-3 py-1.5 rounded-pill me-3 small border border-secondary">
                    <i class="fas fa-user text-info me-2"></i>Rôle actif : <strong>{{ userRole }}</strong>
                </div>
                <a href="/logout" class="btn btn-danger btn-sm fw-bold px-3">
                    <i class="fas fa-sign-out-alt me-1"></i> Déconnexion
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid py-4 px-4">
        
        <div class="mb-4 pb-3 border-bottom">
            <h1 class="fw-bold text-dark">Espace de Gestion des Flux</h1>
            <p class="text-muted m-0">Créez vos demandes et traitez les autorisations logistiques selon vos privilèges de service.</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
                    <i class="fas fa-check-circle me-2"></i> {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card card-counter bg-white p-4 shadow-sm border-start border-warning border-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase small fw-bold">Demandes en attente</h6>
                            <h3 class="fw-bold m-0 text-warning">{{ stats.demandes_attente }}</h3>
                        </div>
                        <i class="fas fa-clock fa-2x text-warning bg-warning bg-opacity-10 p-3 rounded-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-counter bg-white p-4 shadow-sm border-start border-primary border-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase small fw-bold">Bons à signer (Coordon)</h6>
                            <h3 class="fw-bold m-0 text-primary">{{ stats.bons_a_valider }}</h3>
                        </div>
                        <i class="fas fa-pen-nib fa-2x text-primary bg-primary bg-opacity-10 p-3 rounded-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-counter bg-white p-4 shadow-sm border-start border-success border-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase small fw-bold">Bons validés Guérite</h6>
                            <h3 class="fw-bold m-0 text-success">{{ stats.bons_guerite }}</h3>
                        </div>
                        <i class="fas fa-shield-alt fa-2x text-success bg-success bg-opacity-10 p-3 rounded-circle"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            
            {% if userRole != 'ROLE_COORDON' and userRole != 'ROLE_STOCK' and not is_granted('ROLE_GUERITE') %}
            <div class="col-xl-4 col-lg-5">
                <div class="card border-0 shadow-sm mb-4" style="border-top: 4px solid #0d6efd !important;">
                    <div class="card-header bg-white py-3">
                        <h5 class="card-title m-0 fw-bold"><i class="fas fa-box-open text-primary me-2"></i>Demander du Matériel</h5>
                    </div>
                    <div class="card-body">
                        {{ form_start(formDemande) }}
                            {{ form_widget(formDemande) }}
                            <button type="submit" class="btn btn-primary w-100 fw-bold mt-3">Envoyer la Demande</button>
                        {{ form_end(formDemande) }}
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4" style="border-top: 4px solid #198754 !important;">
                    <div class="card-header bg-white py-3">
                        <h5 class="card-title m-0 fw-bold"><i class="fas fa-file-invoice text-success me-2"></i>Créer un Bon de Sortie</h5>
                    </div>
                    <div class="card-body">
                        {{ form_start(formBon) }}
                            {{ form_widget(formBon) }}
                            <button type="submit" class="btn btn-success w-100 fw-bold mt-3">Émettre le Bon</button>
                        {{ form_end(formBon) }}
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="{% if userRole == 'ROLE_COORDON' or userRole == 'ROLE_STOCK' or userRole == 'ROLE_GUERITE' %}col-12{% else %}col-xl-8 col-lg-7{% endif %}">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white p-0 border-bottom">
                        <ul class="nav nav-tabs card-header-tabs m-0 border-bottom-0" id="memberTab" role="tablist">
                            <li class="nav-item">
                                <button class="nav-link active py-3 px-4 fw-bold border-0 text-primary" id="dem-tab" data-bs-toggle="tab" data-bs-target="#dem-pane" type="button" role="tab">
                                    <i class="fas fa-boxes me-2"></i>Suivi des Demandes
                                </button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link py-3 px-4 fw-bold border-0 text-success" id="bon-tab" data-bs-toggle="tab" data-bs-target="#bon-pane" type="button" role="tab">
                                    <i class="fas fa-file-signature me-2"></i>Registre des Bons de Sortie
                                </button>
                            </li>
                        </ul>
                    </div>
                    
                    <div class="card-body p-3">
                        <div class="tab-content">
                            
                            <div class="tab-pane fade show active" id="dem-pane" role="tabpanel">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle m-0">
                                        <thead class="table-light small text-uppercase fw-bold text-secondary">
                                            <tr>
                                                <th>ID</th>
                                                <th>Département</th>
                                                <th>Matériel</th>
                                                <th>Statut</th>
                                                {% if userRole == 'ROLE_STOCK' %}<th class="text-center">Action Stock</th>{% endif %}
                                            </tr>
                                        </thead>
                                        <tbody class="small">
                                            {% for d in demandes %}
                                                <tr>
                                                    <td class="fw-bold">#{{ d.id }}</td>
                                                    <td><span class="badge bg-secondary bg-opacity-10 text-secondary border px-2 py-1">{{ d.departement }}</span></td>
                                                    <td class="fw-semibold text-dark">{{ d.materiel }}</td>
                                                    <td><span class="badge rounded-pill px-2.5 py-1 bg-warning text-dark">{{ d.statut }}</span></td>
                                                    
                                                    {% if userRole == 'ROLE_STOCK' %}
                                                    <td class="text-center">
                                                        <form action="{{ path('app_demande_livrer', {'id': d.id}) }}" method="POST" class="d-inline">
                                                            <button class="btn btn-sm btn-outline-success fw-bold"><i class="fas fa-truck me-1"></i> Livrer le matériel</button>
                                                        </form>
                                                    </td>
                                                    {% endif %}
                                                </tr>
                                            {% else %}
                                                <tr><td colspan="5" class="text-center py-4 text-muted">Aucune demande logistique enregistrée.</td></tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="bon-pane" role="tabpanel">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle m-0">
                                        <thead class="table-light small text-uppercase fw-bold text-secondary">
                                            <tr>
                                                <th>ID</th>
                                                <th>Employé</th>
                                                <th>Département</th>
                                                <th>État du Bon</th>
                                                {% if userRole == 'ROLE_COORDON' %}<th class="text-center">Signature Coordon</th>{% endif %}
                                            </tr>
                                        </thead>
                                        <tbody class="small">
                                            {% for b in bonsSortie %}
                                                <tr>
                                                    <td class="fw-bold">#{{ b.id }}</td>
                                                    <td class="fw-semibold text-dark">{{ b.nomEmploye }}</td>
                                                    <td><span class="badge bg-secondary bg-opacity-10 text-secondary border px-2 py-1">{{ b.departement }}</span></td>
                                                    <td><span class="badge rounded-pill px-2.5 py-1 bg-primary text-white">{{ b.statut }}</span></td>
                                                    
                                                    {% if userRole == 'ROLE_COORDON' %}
                                                    <td class="text-center">
                                                        <form action="{{ path('app_bon_valider', {'id': b.id}) }}" method="POST" class="d-inline">
                                                            <button class="btn btn-sm btn-success fw-bold px-3 shadow-sm">
                                                                <i class="fas fa-pen-fancy me-1"></i> Signer le Bon
                                                            </button>
                                                        </form>
                                                    </td>
                                                    {% endif %}
                                                </tr>
                                            {% else %}
                                                <tr><td colspan="5" class="text-center py-4 text-muted">Aucun bon de sortie en traitement.</td></tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                {% if not is_granted('ROLE_GUERITE') and formVisite is not null %}
                <div class="card border-0 shadow-sm mt-4" style="border-top: 4px solid #ffc107 !important;">
                    <div class="card-header bg-white py-3">
                        <h5 class="card-title m-0 fw-bold text-warning"><i class="fas fa-calendar-alt me-2"></i>Réserver une Visite</h5>
                    </div>
                    <div class="card-body">
                        {{ form_start(formVisite) }}
                            <div class="row">
                                {# 1. Nom du visiteur #}
                                <div class="col-md-4 mb-3">
                                    <label class="form-label small fw-bold">Nom du Visiteur</label>
                                    {{ form_widget(formVisite.nomVisiteur, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Jean Dupont'}}) }}
                                </div>

                                {# 2. Département Visité #}
                                <div class="col-md-4 mb-3">
                                    <label class="form-label small fw-bold">Département Visité</label>
                                    {{ form_widget(formVisite.departement, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Impression'}}) }}
                                </div>

                                {# 3. Motif de la visite #}
                                <div class="col-md-4 mb-3">
                                    <label class="form-label small fw-bold">Motif de la visite</label>
                                    {{ form_widget(formVisite.motif, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Réunion, Maintenance'}}) }}
                                </div>
                            </div>
                            <button type="submit" class="btn btn-warning w-100 text-white fw-bold mt-2">Enregistrer la Visite</button>
                        {{ form_end(formVisite) }}
                    </div>
                </div>
                {% endif %}

            </div> </div> </div> <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>