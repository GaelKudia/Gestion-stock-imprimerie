{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord - Imprimerie{% endblock %}

{% block body %}
<div class="container mt-4">
    
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-dark m-0">📋 Tableau de Bord Principal</h1>
            <p class="text-muted">Session active : <strong>{{ app.user ? app.user.userIdentifier : 'Gael (Mode Dév)' }}</strong> — Rôle : <code>{{ userRole }}</code></p>
        </div>
        <button type="button" class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#actionModal">
            ✨ Nouvelle Action / Formulaire
        </button>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-warning text-dark shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column justify-content-center py-4">
                    <h6 class="text-uppercase fw-bold opacity-75 mb-1">Demandes Matériel en attente</h6>
                    <h2 class="display-5 fw-bold m-0">{{ stats.demandes_attente }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-primary text-white shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column justify-content-center py-4">
                    <h6 class="text-uppercase fw-bold opacity-75 mb-1">Bons de sortie en attente de Signature</h6>
                    <h2 class="display-5 fw-bold m-0">{{ stats.bons_a_valider }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-success text-white shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column justify-content-center py-4">
                    <h6 class="text-uppercase fw-bold opacity-75 mb-1">Flux validés en attente à la Guérite</h6>
                    <h2 class="display-5 fw-bold m-0">{{ stats.bons_guerite }}</h2>
                </div>
            </div>
        </div>
    </div>

    <hr class="my-4">

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0 fw-bold">📦 Gestion des Demandes d'Articles (Stock)</h5>
                </div>
                <div class="card-body">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Département</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for demande in demandes %}
                                <tr>
                                    <td><strong>#{{ demande.id }}</strong></td>
                                    <td>{{ demande.departement }}</td>
                                    <td>
                                        <span class="badge bg-{{ demande.statut == 'En attente' ? 'warning text-dark' : (demande.statut == 'Livré par le Stock' ? 'info text-dark' : 'success') }}">
                                            {{ demande.statut }}
                                        </span>
                                    </td>
                                    <td>
                                        {% if demande.statut == 'En attente' and userRole == 'ROLE_STOCK' %}
                                            <form action="{{ path('app_demande_livrer', {'id': demande.id}) }}" method="POST" class="d-inline">
                                                <button class="btn btn-sm btn-outline-primary fw-bold">🚚 Livrer</button>
                                            </form>
                                        {% elseif demande.statut == 'Livré par le Stock' and userDept == demande.departement %}
                                            <form action="{{ path('app_demande_recevoir', {'id': demande.id}) }}" method="POST" class="d-inline">
                                                <button class="btn btn-sm btn-success fw-bold">✅ Reçu</button>
                                            </form>
                                        {% else %}
                                            <span class="text-muted small">Aucune action</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">Aucune demande enregistrée.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-secondary text-white py-3">
                    <h5 class="mb-0 fw-bold">🛡️ Registre de Sécurité & Circuits de Sortie</h5>
                </div>
                <div class="card-body">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Demandeur</th>
                                <th>Département</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for bon in bonsSortie %}
                                <tr>
                                    <td><strong>{{ bon.nomEmploye }}</strong></td>
                                    <td>{{ bon.departement }}</td>
                                    <td>
                                        <span class="badge bg-{{ bon.statut == 'Créé' ? 'secondary' : (bon.statut == 'Validé Coordon' ? 'primary' : 'success') }}">
                                            {{ bon.statut }}
                                        </span>
                                    </td>
                                    <td>
                                        {% if bon.statut == 'Créé' and userRole == 'ROLE_COORDON' %}
                                            <form action="{{ path('app_bon_valider', {'id': bon.id}) }}" method="POST" class="d-inline">
                                                <button class="btn btn-sm btn-primary fw-bold">✍️ Signer</button>
                                            </form>
                                        {% elseif bon.statut == 'Validé Coordon' and userRole == 'ROLE_GUERITE' %}
                                            <form action="{{ path('app_bon_autoriser', {'id': bon.id}) }}" method="POST" class="d-inline">
                                                <button class="btn btn-sm btn-success fw-bold">🚪 Autoriser</button>
                                            </form>
                                        {% else %}
                                            <span class="text-muted small">En attente</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">Aucun document en attente de traitement pour votre rôle.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="actionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Créer un nouveau document</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs mb-3" id="modalTab" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active fw-bold" id="demande-tab" data-bs-toggle="tab" data-bs-target="#demande-panel" type="button" role="tab">📦 Demande Stock</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold" id="bon-tab" data-bs-toggle="tab" data-bs-target="#bon-panel" type="button" role="tab">🚀 Bon de Sortie</button>
                    </li>
                </ul>
                <div class="tab-content" id="modalTabContent">
                    <div class="tab-pane fade show active" id="demande-panel" role="tabpanel">
                        {{ form_start(formDemande) }}
                            {{ form_widget(formDemande) }}
                            <button type="submit" class="btn btn-success mt-3 w-100 fw-bold">Envoyer la Demande</button>
                        {{ form_end(formDemande) }}
                    </div>
                    <div class="tab-pane fade" id="bon-panel" role="tabpanel">
                        {{ form_start(formBon) }}
                            {{ form_widget(formBon) }}
                            <button type="submit" class="btn btn-primary mt-3 w-100 fw-bold">Générer le Bon</button>
                        {{ form_end(formBon) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}